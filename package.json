{
  "name": "robsonalvesdevbr-angular",
  "version": "2.2.0",
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port 4200",
    "start:prod": "ng serve --configuration production",
    "dev": "ng serve --open",
    "build": "ng build --configuration development",
    "build:prod": "ng build --configuration production --optimization",
    "build:stats": "ng build --configuration production --stats-json",
    "build:analyze": "pnpm run build:stats && pnpm exec webpack-bundle-analyzer dist/robsonalves/stats.json",
    "watch": "ng build --watch --configuration development",
    "test": "vitest",
    "test:nowatch": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "format": "prettier --write \"src/**/*.{ts,html,scss,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss,json}\"",
    "clean": "rm -rf dist node_modules/.cache .angular",
    "analyze": "pnpm run build:stats && pnpm exec webpack-bundle-analyzer dist/robsonalves/stats.json --port 8888",
    "security:check": "pnpm audit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:webkit": "playwright test --project=webkit",
    "test:e2e:mobile": "playwright test --project=mobile-chrome --project=mobile-safari",
    "test:e2e:report": "playwright show-report"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^22.0.6",
    "@angular/compiler": "^22.0.6",
    "@angular/core": "^22.0.6",
    "@angular/platform-browser": "^22.0.6",
    "@angular/platform-browser-dynamic": "^22.0.6",
    "@angular/router": "^22.0.6",
    "@popperjs/core": "^2.11.8",
    "bootstrap-icons": "^1.13.1",
    "ngx-google-analytics": "^14.0.1",
    "ngx-pagination": "6.0.3",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^22.1.0",
    "@angular/build": "^22.0.6",
    "@angular/cli": "^22.0.6",
    "@angular/compiler-cli": "^22.0.6",
    "@playwright/test": "^1.61.1",
    "@types/jasmine": "^5.1.15",
    "@typescript/native": "npm:typescript@^7.0.2",
    "@vitest/browser": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "angular-eslint": "^22.1.0",
    "bootstrap": "^5.3.8",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "istanbul-lib-instrument": "^6.0.3",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^7.3.6",
    "vitest": "^4.1.10",
    "webpack-bundle-analyzer": "^5.3.0",
    "zone.js": "^0.16.2"
  }
}
